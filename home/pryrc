if RUBY_PLATFORM.match?(/darwin/i)
  def pbcopy(data)
    IO.popen 'pbcopy', 'w' do |io|
      io << data
    end
    nil
  end

  def pbpaste
    `pbpaste`
  end

  Pry.config.commands.command "cp", "Copy last result to clipboard, -m for multiline copy" do
    multiline = arg_string == '-m'
    pbcopy pry_instance.last_result.ai(plain: true, indent: 2, index: false, multiline: multiline)
    output.puts "    📄 copied#{multiline ? ' multiline!' : '!'}"
  end

  Pry.config.commands.command "cpc", "Copy last command to clipboard" do
    ring = pry_instance.input_ring.to_a
    pbcopy ring[ring.size - 1]
    output.puts "    📄 copied!"
  end
end

