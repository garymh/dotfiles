Pry::Commands.command("stack", "where am i really though") do
  pwd = `pwd`.delete("\n")
  filtered = caller.select do |path|
    !path.include?("pry") &&
      !path.include?("byebug") &&
      !path.include?("ruby/gems/") &&
      !path.include?("bundler/vendor") &&
      !path.include?(".asdf/installs/ruby")
  end
  filtered = filtered.map { |path| path.gsub(pwd, "") }
  Pry::Pager.new(pry_instance).page(filtered.join("\n"))
end

Pry::Commands.command "caller_method" do |depth|
  depth = depth.to_i || 1
  if /^(.+?):(\d+)(?::in `(.*)')?/ =~ caller(depth + 1).first
    file   = Regexp.last_match[1]
    line   = Regexp.last_match[2].to_i
    method = Regexp.last_match[3]
    output.puts [file, line, method]
  end
end

