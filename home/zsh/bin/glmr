#!/usr/bin/env ruby
# vi:syntax=ruby

require_relative 'glhelper'

if on_default_branch?
  `open "https://gitlab.com/dashboard/merge_requests?assignee_username=garyh"`
else
  mrs = JSON.parse(File.read('/tmp/gitlab/MRs.json'))
  mr  = mrs.find { |i| i["source_branch"] == @branch }

  `open #{mr["web_url"]}`
end
