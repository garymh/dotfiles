#!/usr/bin/env bash

# wait4pipeline uses pipelinestatus to monitor a GitLab CI Pipeline run and
# displays an alert dialog using AppleScript to let you know when it finishes
# and wether it failed or succeeded.
#
# Example:
#
#  $ wait4pipeline "<pipeline url>"

set -o errexit
set -o nounset
set -o pipefail

if [ "${1:-}" = "" ]; then
  echo "usage: $(basename "$0") https://gitlab.com/<project>/-/pipelines/<id>"
  exit 1
fi

if pipelinestatus "$1"; then
  osascript -e 'display alert "✅ Pipeline Finished" message "" buttons {"OK"} default button "OK"'
  exit 0
else
  osascript -e 'display alert "❌ Pipeline Failed" message "" as critical buttons {"OK"} default button "OK"'
  exit 1
fi
