[maintenance]
	repo = /Users/gary/code/work/gitlab-development-kit/gitlab
	repo = /Users/gary/code/work/gitlab-development-kit
	repo = /Users/gary/code/work/gdk
	repo = /Users/gary/code/work/gdk/gitlab
[diff]
	tool = Kaleidoscope
[difftool "Kaleidoscope"]
	cmd = ksdiff --partial-changeset --relative-path \"$MERGED\" -- \"$LOCAL\" \"$REMOTE\"
[difftool]
	prompt = false
	trustExitCode = true
[merge]
	tool = Kaleidoscope
[mergetool "Kaleidoscope"]
	cmd = ksdiff --merge --output \"$MERGED\" --base \"$BASE\" -- \"$LOCAL\" --snapshot \"$REMOTE\" --snapshot
	trustExitCode = true
[mergetool]
	prompt = false

