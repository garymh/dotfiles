# vi: ft=gitconfig sw=2

[core]
  excludesfile = ~/code/dotfiles/home/gitignore_global
  whitespace   = space-before-tab,-indent-with-non-tab,trailing-space
  editor       = nvim

  # Make `git rebase` safer on OS X
  # More info: <http://www.git-tower.com/blog/make-git-rebase-safe-on-osx/>
  trustctime = false

  # Prevent showing files whose names contain non-ASCII symbols as unversioned.
  # http://michael-kuehnel.de/git/2014/11/21/git-mac-osx-and-german-umlaute.html
  precomposeunicode = false

	untrackedCache = true
[alias]
  fresh                  = remote update --prune
  changes                = "!git log --oneline --invert-grep --grep=\"Merge branch\" --invert-grep --grep="chore" $(git describe --tags --abbrev=0)..main"
  abbrev                 = !bash -c 'git rev-parse --short ${1-`echo HEAD`}' -
  abbrev-ref             = rev-parse --abbrev-ref HEAD
  amend                  = commit -a --amend
  back-to-origin         = !git reset --hard origin/`git symbolic-ref --short HEAD`
  back-to-security       = !git reset --hard security/`git symbolic-ref --short HEAD`
  co                     = checkout
  delete-local-branch    = branch -D
  delete-merged-branches = "!delete-merged-branches"
  discard                = checkout --
  edit                   = !$EDITOR $(git status --porcelain | awk '{print $2}')
  explode                = !git reset --hard HEAD && git clean -d -f
  fuckthis               = !git reset --hard HEAD && git clean -d -f
  kmr-changes            = !git ksdiff `git merge-base master HEAD`
  ksdiff                 = difftool
  mr                     = !sh -c 'git fetch $1 merge-requests/$2/head:mr-$1-$2 && git checkout mr-$1-$2' -
  mr-changes             = !git diff `git merge-base master HEAD`
  ours                   = "!f() { git co --ours $@ && git add $@; }; f"
  remotes                = remote -v
  remove-local-branch    = branch -D
  rename-local-branch    = branch -m
  rmfiles                = clean -fdx
  rspec                  = !git_rspec "$@"
  set-security-upstream  = !git branch --set-upstream-to=security/`git symbolic-ref --short HEAD`
  set-upstream           = !git branch --set-upstream-to=origin/`git symbolic-ref --short HEAD`
  stashes                = stash list
  theirs                 = "!f() { git co --theirs $@ && git add $@; }; f"
  uncommit               = reset --mixed HEAD~
  undo                   = reset --mixed HEAD~
  ; cb = !git checkout $(git branch | fzf | tr -d "[:space:]")
  unpushed               = rebase -i @{u}
  unstage                = reset -- $1
  unundo                 = reset 'HEAD@{1}'
  up                     = !git pull --rebase --prune $@ && git submodule update --init --recursive
  update-submodules      = submodule update --init --recursive
  url                    = "!glmr"
  vim-status             = "!f() { vim_status; }; f"
  vim-untracked-status   = "!f() { vim_untracked_status; }; f"

  ; git log -LN,M:/path/to-file

[color]
  branch      = auto
  diff        = auto
  interactive = auto
  status      = auto
  ui          = true

[gc]
  reflogExpire            = 200
  reflogExpireUnreachable = 90

[fetch]
  prune = true

[web]
  browser = open

[status]
  showUntrackedFiles = all

[help]
  autocorrect = 1

[filter "lfs"]
  required = true
  clean    = git-lfs clean -- %f
  smudge   = git-lfs smudge -- %f
  process  = git-lfs filter-process

[include]
  path    = ~/.gitconfig.local

[includeIf "gitdir:~/code/work/"]
  path     = ~/.gitconfig.work
  fsmonitor = true

[rebase]
  autoStash = true
  autosquash = true
	instructionFormat = %<|(120) %s (%ar) <%an>

[stash]
  showIncludeUntracked = true

[apply]
  whitespace = nowarn

[branch]
  autosetuprebase = always

[push]
  default = current
	autoSetupRemote = true
  ; autoSetupRemote = true

[pull]
  default = current
  ff = only

[url "git@github.com:"]
  insteadOf = https://github.com/

[url "git@gitlab.com:"]
  insteadOf = https://gitlab.com/

[rerere]
  enabled = true

[interactive]
  diffFilter = delta --color-only --features=interactive

[delta]
  features = unobtrusive-line-numbers decorations
  whitespace-error-style = 22 reverse
  ; side-by-side = true
  line-numbers = true
  navigate = true
  relative-paths = true
  ; hyperlinks = true
  theme = Sublime Snazzy

[delta "unobtrusive-line-numbers"]
  line-numbers = true
  line-numbers-minus-style = "#444444"
  line-numbers-zero-style = "#444444"
  line-numbers-plus-style = "#444444"
  line-numbers-left-format = "{nm:>4}┊"
  line-numbers-right-format = "{np:>4}│"
  line-numbers-left-style = blue
  line-numbers-right-style = blue

[delta "interactive"]
  keep-plus-minus-markers = false

[delta "decorations"]
  commit-decoration-style = blue ol
  commit-style = raw
  file-style = omit
  hunk-header-decoration-style = blue box
  hunk-header-file-style = red
  hunk-header-line-number-style = "#067a00"
  hunk-header-style = file line-number syntax

[commit]
  template = .git/commit-msg

[features]
  manyfiles = true
[init]
	defaultBranch = main

