# Start configuration added by Zim install {{{
#
# This is not sourced during shell startup, and it's only used to configure the
# zimfw plugin manager.

zmodule environment
zmodule git
zmodule input
zmodule termtitle
zmodule skywind3000/z.lua --cmd 'eval "$(lua {}/z.lua --init zsh enhanced once)"'
zmodule zshzoo/macos

zmodule romkatv/powerlevel10k --use degit

zmodule day50-dev/Zummoner

zmodule duration-info

zmodule fzf
zmodule joke/zim-mise
zmodule magic-enter

zmodule atuin-init --use mkdir --if-command atuin \
  --cmd 'if [[ ! {}/init.zsh -nt ${commands[atuin]} ]]; then
  atuin init --disable-up-arrow zsh > {}/init.zsh
  zcompile -UR {}/init.zsh
  fi' \
  --source init.zsh

zmodule junegunn/fzf-git.sh --source fzf-git.sh

zmodule zsh-users/zsh-completions --fpath src

if [[ -d /opt/homebrew/share/zsh ]] && [[ $(uname) == Darwin ]] ; then
    zmodule /opt/homebrew/share/zsh --fpath site-functions
fi

zmodule completion

# zmodule decayofmind/zsh-fast-alias-tips
# this needs to run make build! (somehow?)
zmodule shanwker1223/zim-alias-finder

zmodule zsh-users/zsh-syntax-highlighting
zmodule zsh-users/zsh-history-substring-search
zmodule zsh-users/zsh-autosuggestions
