Reline::Face.force_truecolor if defined?(Reline::Face)

IRB.conf[:EVAL_HISTORY] = 10

# IRB.conf[:USE_AUTOCOMPLETE] = false

class Object
  def ims
    (methods - Object.instance_methods).sort
  end
end

module AutoloadPrettyPrint
  def pp(*args)
    require 'pp' unless defined?(super)
    super
    nil
  end
end

include AutoloadPrettyPrint

class Object
  def o
    pp self
    self
  end
end

