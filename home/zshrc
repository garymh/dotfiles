#!/usr/local/bin/zsh

typeset -F4 SECONDS=0

### Added by Zinit's installer
if [[ ! -f $HOME/.zinit/bin/zinit.zsh ]]; then
    print -P "%F{33}▓▒░ %F{220}Installing %F{33}DHARMA%F{220} Initiative Plugin Manager (%F{33}zdharma/zinit%F{220})…%f"
    command mkdir -p "$HOME/.zinit" && command chmod g-rwX "$HOME/.zinit"
    command git clone https://github.com/zdharma/zinit "$HOME/.zinit/bin" && \
        print -P "%F{33}▓▒░ %F{34}Installation successful.%f%b" || \
        print -P "%F{160}▓▒░ The clone has failed.%f%b"
fi

source "$HOME/.zinit/bin/zinit.zsh"
autoload -Uz _zinit
(( ${+_comps} )) && _comps[zinit]=_zinit

# Load a few important annexes, without Turbo
# (this is currently required for annexes)
zinit light-mode for \
    zinit-zsh/z-a-rust \
    zinit-zsh/z-a-as-monitor \
    zinit-zsh/z-a-patch-dl \
    zinit-zsh/z-a-bin-gem-node
### End of Zinit's installer chunk

zinit ice svn
zinit snippet OMZP::tmux

# most of the things below thieved from https://github.com/Seirdy/dotfiles
# guy is a genius.
function z_lucid() {
  zinit ice lucid ver'master' "$@"
}
function zi0a() {
  z_lucid wait'0a' "$@"
}
function zi0b() {
  z_lucid wait'0b' "$@"
}
function zi0c() {
  z_lucid wait'0c' "$@"
}

omz_plugins=(
  zsh_reload
  fasd
  colored-man-pages
  github
  thefuck
  rake-fast
  fancy-ctrl-z
  git
)

zinit snippet OMZ::lib/key-bindings.zsh
for plugin in ${omz_plugins[@]}; do zinit snippet OMZP::$plugin; done

zinit ice atload"unalias sd"
zinit snippet OMZP::fasd

zinit load mafredri/zsh-async
zinit load "$HOME/code/fzf-widgets"

zi0b pick"bin/git-fuzzy" as"program"
zinit load bigH/git-fuzzy

zi0b
zinit load djui/alias-tips

zi0b
zinit load paoloantinori/hhighlighter

zi0b
zinit load unixorn/git-extra-commands

zi0c
zinit load RobSis/zsh-completion-generator

zinit wait lucid light-mode for \
  atload"_zsh_autosuggest_start" \
      zsh-users/zsh-autosuggestions \
  blockf atpull'zinit creinstall -q .' \
      zsh-users/zsh-completions

# From: https://github.com/sgleizes/dotfiles/blob/0b9fa9ced2ba2bc189ba6ba47d8672b8a8f4fa8e/.xsh/zsh/module/git/%40interactive.zsh
# Automatically detect and escape zsh globbing meta-characters when used with
# git refspec characters like `[^~{}]`. NOTE: This must be loaded _after_
# url-quote-magic, which is the motivation for the zinit 'wait slot'.
# The plugin is patched to work with all defined git wrappers and aliases.
zinit ice wait'0b' lucid depth=1 reset \
  atclone'sed -i "s;(\*/|)git;(*/|)("${(j:|:)$(_list_git_wrappers)}");g" git-escape-magic' \
  atpull'%atclone' nocompile'!' \
  pick'git-escape-magic'
zinit light knu/zsh-git-escape-magic

zinit ice wait"0c" lucid reset \
    atclone"local P=${${(M)OSTYPE:#*darwin*}:+g}
            \${P}sed -i \
            '/DIR/c\DIR 38;5;63;1' LS_COLORS; \
            \${P}dircolors -b LS_COLORS > c.zsh" \
    atpull'%atclone' pick"c.zsh" nocompile'!' \
    atload'zstyle ":completion:*" list-colors “${(s.:.)LS_COLORS}”'
zinit light trapd00r/LS_COLORS

if [[ $(zsh --version | awk '{print $2}') > 5.0.7 ]]; then
  eval "$(starship init zsh)"

  zi0a pick'autopair.zsh'
  zinit light hlissner/zsh-autopair
fi

function zi_completion() {
zi0a as'completion' blockf "$@"
}

zi_completion has'rg'
zinit snippet https://github.com/BurntSushi/ripgrep/blob/master/complete/_rg

zi_completion has'fd'
zinit snippet https://github.com/ohmyzsh/ohmyzsh/blob/master/plugins/fd/_fd

zi_completion has'exa' mv'completions.zsh -> _exa'
zinit snippet https://github.com/ogham/exa/blob/master/completions/completions.zsh

zi_completion has'brew'
zinit snippet https://github.com/Homebrew/brew/tree/master/completions/zsh/_brew

# zi_completion has'git'
# zinit snippet https://github.com/git/git/blob/master/contrib/completion/git-completion.zsh

zi_completion has'git'
zinit snippet https://github.com/git/git/blob/master/contrib/completion/git-completion.bash

# zi0b as'completion'
# zinit light $DOTFILES/home/zsh/completions

if [[ ! -d ~/.tmux/plugins/tpm ]]; then
  git clone https://github.com/tmux-plugins/tpm.git --depth 1 ~/.tmux/plugins/tpm 2> /dev/null
fi

for f ($DOTFILES/home/zsh/*.sh) { source $f }

[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

# Added by GDK bootstrap
export PKG_CONFIG_PATH="/usr/local/opt/icu4c/lib/pkgconfig:${PKG_CONFIG_PATH}"
export RUBY_CONFIGURE_OPTS="--with-openssl-dir=/usr/local/opt/openssl@1.1 --with-readline-dir=/usr/local/opt/readline"

source "$HOME/.asdf/asdf.sh"

echo ""
e_success "${SHELL} ${ZSH_VERSION} loaded in ${(M)$(( SECONDS * 1000 ))#*.?} ms"
