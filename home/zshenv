source $HOME/.zsh/misc/utility.zsh

export COMPLETION_WAITING_DOTS="true"
export CPPFLAGS="-I/usr/local/opt/icu4c/include"
export DOTFILES="$HOME/code/dotfiles"
export GITLAB_MAIN_BRANCH="master"
export GPG_TTY=$(tty)
export HISTFILE="$HOME/.zsh_history"
export HISTSIZE=10000000
export HOMEBREW_BAT=1
export HOMEBREW_BUNDLE_FILE_PATH="$DOTFILES/Brewfile"
export HOMEBREW_CASK_OPTS="--fontdir=~/Library/Fonts"
export HOMEBREW_DISPLAY_INSTALL_TIMES=1
export HOMEBREW_NO_ANALYTICS=1
export HOME_DIR="$DOTFILES/home"
export LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8
export LDFLAGS="-L/usr/local/opt/icu4c/lib"
export MY_RUBY_HOME="$HOME/.asdf/shims/ruby"
export NAVI_PATH="$DOTFILES/home/doc"
export NEXTWORD_DATA_PATH="$HOME/.config/nextword-data"
export OCI_DIR=/usr/local/lib
export PKG_CONFIG_PATH="/usr/local/opt/icu4c/lib/pkgconfig"
export RIPGREP_CONFIG_PATH="$HOME/.config/ripgrep/config"
export SAVEHIST=10000000
export VIMFILES="$HOME/code/dotfiles/home/vim"
export ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE="fg=239"
export ZSH_AUTOSUGGEST_USE_ASYNC="true"
export ZSH_PLUGINS_ALIAS_TIPS_EXCLUDES=":q gco g rubocop"
export ZSH_PLUGINS_ALIAS_TIPS_REVEAL=1

if [ "$TERM" = "alacritty" ]; then
  export ZSH_TMUX_AUTOSTART="true"
fi

export PATH="/usr/local/bin:$PATH"
export PATH=$HOME_DIR/zsh/bin:$PATH
export PATH="/usr/local/sbin:$PATH"
export PATH="$HOME/Library/Python/3.9/bin:$PATH"

if _exists go; then export PATH=$PATH:$HOME/code/go/bin; fi
if _exists cargo; then export PATH=$PATH:$HOME/.cargo/bin; fi

export EDITOR="$VISUAL"
if _exists nvim; then export VISUAL='nvim'; fi

setopt   EXTENDED_HISTORY   # Write the history file in the ":start:elapsed;command" format.
setopt   HIST_FIND_NO_DUPS  # Do not display a line previously found.
setopt   HIST_REDUCE_BLANKS # Remove superfluous blanks before recording entry.
setopt   SHARE_HISTORY      # Share history between all sessions.
setopt   always_to_end      # always move to the end of the word if completion worked
setopt   auto_menu          # show completion menu on successive tab press
setopt   complete_in_word
unsetopt correct_all        # don't autocorrect when thefuck does it better.
unsetopt flowcontrol        # gives me back ^-S



for f in ~/.zsh/private/*.zsh(N); do
  [ -e "$f" ] && source $f || break
done
