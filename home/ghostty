# vim: set filetype=ghostty :

custom-shader = shaders/cursor_blaze_no_trail.glsl

font-feature = -calt
font-feature = -dlig
font-feature = -liga
font-feature = cv03
font-feature = cv04
font-feature = ss05
font-feature = zero

# keybind = cmd+shift+f=toggle_fullscreen
# ❯ kitten show_key
keybind = cmd+shift+grave_accent=toggle_quick_terminal
keybind = cmd+shift+t=undo
keybind = cmd+left=text:\x01
keybind = cmd+right=text:\x05
keybind = opt+right=esc:f
keybind = opt+left=esc:b
keybind = opt+delete=esc:d
keybind = cmd+backspace=text:\x15
keybind = super+d=new_split:down
keybind = super+shift+d=new_split:right
keybind = global:cmd+escape=toggle_quick_terminal
keybind = ctrl+enter=text:\r
keybind = shift+enter=text:\n

clipboard-read                    = allow
clipboard-write                   = allow
confirm-close-surface             = false
cursor-opacity                    = 0.5
quick-terminal-animation-duration = 0.1
quick-terminal-position           = right
quick-terminal-size               = 45%,50%
theme                             = Rose Pine Moon
window-padding-balance            = true
window-padding-x                  = 10
window-padding-y                  = 10
window-theme                      = system
window-vsync                      = false
notify-on-command-finish          = unfocused
window-inherit-working-directory  = false
tab-inherit-working-directory     = true
split-inherit-working-directory   = true
progress-style                    = true

keybind = ctrl+shift+f=toggle_fullscreen
keybind = chain=toggle_window_decorations

