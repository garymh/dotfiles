  {:des "pacman ghost piktea" :rules                      [[:f2 "shortcuts run \"AUTO: Pacman Ghost\"" :pikatea]]}
  ]
 }
  ;; !  | means mandatory
  ;; #  | means optional
  ;; C  | left_command
  ;; T  | left_control
  ;; O  | left_option
  ;; S  | left_shift
  ;; F  | fn
  ;; Q  | right_command
  ;; W  | right_control
  ;; E  | right_option
  ;; R  | right_shift
  ;; P  | caps_lock
  ;; !! | mandatory command + control + optional + shift (hyper)
  ;; ## | optional any,w
