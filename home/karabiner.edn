 {:des "Double-tap option ⌘ → omnifocus"
         :rules [
           [:##left_option :left_option ["tunadt_left_opt_pressed" 1]
            {:alone [:!!x ["tunadt_left_opt_pressed" 0]]}]

           [:##left_option :left_option nil
            {:alone [["tunadt_left_opt_pressed" 1]]
             :delayed {:invoked  ["tunadt_left_opt_pressed" 0]
                       :canceled ["tunadt_left_opt_pressed" 0]}
             :params {:alone 300 :delay 300}}]
         ]}

  {:des "right option to globe" :rules [[:##right_option :####fn]]}
  {:des "fn key -> hyper key or f16 if alone"
   :rules
   [:qmkbundle
    [:##fn nil nil {:alone :##f16 :held :!!left_shift}]
    [:##left_control :!!left_shift nil {:alone :##f16}]
    [:##caps_lock :right_control nil {:alone :##f15}]
    [:##f15 :right_control nil {:alone :##f15}]]}

  {:des "shift + delete -> forward delete" :rules         [[:!Sdelete_or_backspace :##delete_forward]]}
  {:des "cmd space"
   :rules
   [[:!Cspacebar [:f18 ["in-alfred" 1]]]

    :in-alfred ;; when "in-alfred" is 1
               ;; press enter will select one alfred result and set "in-alfred" to 0
    [:##return_or_enter [:return_or_enter ["in-alfred" 0]]]
               ;; press esc will exit alfred and set "in-alfred" to 0
    [:##escape [:escape ["in-alfred" 0]]]
               ;; press ctrl + l will invoke return_or_enter and set "in-alfred" to 0
    [:!Tl [:return_or_enter ["in-alfred" 0]]]]}

  {:des "|mail| <c-c> to ⌘⇧c (conversations)" :rules      [[:!Tc :!CSc :mail]]}
  {:des "|mail| <c-/> to ⌘⌥f" :rules                      [[:!Wslash :!COf :mail]]}
  {:des "|mail| ⌘⌥return sends" :rules                    [[:!Creturn_or_enter :!SCd :mail]]}

  {:des "|reeder| ⌘⇧r -> R" :rules                        [[:!CSr :r :reeder]]}

  {:des "|safari| undo close window" :rules               [[:!CSn :!CSt :safari]]}
  {:des "|safari| undo close tab" :rules                  [[:!CSz :!CSt :safari]]}
  {:des "|safari| private window" :rules                  [[:!CSp :!CSn :safari]]}
  {:des "|helium| private window" :rules                  [[:!CSp :!CSn :helium]]}
  {:des "|brave| private window" :rules                   [[:!CSp :!CSn :brave]]}

  {:des "|ghostty| alt+f" :rules                          [[:!CSf :!Of :ghostty]]}
  {:des "|ghostty| alt+g" :rules                          [[:!CSg :!Og :ghostty]]}
  {:des "|ghostty| opt+k" :rules                          [[:!Ck :!Ok :ghostty]]}
  {:des "|ghostty| opt+p" :rules                          [[:!Cp :!Op :ghostty]]}

  {:des "|1password| easier shortcut" :rules              [[:!Cl :!Cf :onep]]}

  {:des "|terminals| vim history fix" :rules              [[:!Ti :f6 :terminals]]}

  {:des "|terminal| ⌥ delete" :rules                      [[:!Odelete_or_backspace :!Tw :terminal]]}
  {:des "|terminal| ⌘ delete" :rules                      [[:!Cdelete_or_backspace :!Tu :terminals]]}
  {:des "|terminal| ⌘ return" :rules                      [[:!Creturn_or_enter :!Oreturn_or_enter :terminals]]}
  {:des "|terminal| ⌘ <- to ctrl-a" :rules                [[:!Cleft_arrow :!Ta :terminal]]}
  {:des "|terminal| ⌘ -> to ctrl-e" :rules                [[:!Cright_arrow :!Te :terminal]]}
  {:des "|terminal| ⌘ <- to ctrl-a" :rules                [[:!CTh :!Ta :terminal]]}
  {:des "|terminal| ⌘ -> to ctrl-e" :rules                [[:!CTl :!Te :terminal]]}

  {:des "|omnifocus| defer to tomorrow" :rules            [[:!Cright_arrow [:applescript "defer-to-tomorrow"] :omnifocus]]}

  {:des "vim ctrl arrow key left" :rules                  [[:!W##h :##left_arrow]]}
  {:des "vim ctrl arrow key right" :rules                 [[:!W##l :##right_arrow]]}
  {:des "vim ctrl arrow key up" :rules                    [[:!W##k :##up_arrow]]}
  {:des "vim ctrl arrow key down" :rules                  [[:!W##j :##down_arrow]]}
  {:des "vim ctrl arrow key left" :rules                  [[:!T##h :##left_arrow]]}
  {:des "vim ctrl arrow key right" :rules                 [[:!T##l :##right_arrow]]}
  {:des "vim ctrl arrow key up" :rules                    [[:!T##k :##up_arrow]]}
  {:des "vim ctrl arrow key down" :rules                  [[:!T##j :##down_arrow]]}

  {:des "clear notifications" :rules                      [[:!!delete_or_backspace [:alfred "clearnots" "com.garys.stuff"]]]}
  {:des "mousetest?" :rules                               [[:keypad_1 :f15 :mouse]]}
  {:des "mousetest?2" :rules                              [[:keypad_2 :!Sf15 :mouse]]}
  {:des "double shift" :rules                             [[:butt :f19]]}

  {:des "KVM?" :rules                                     [[:!Sf24 [:monitor_control]]]}

  {:des "F13" :rules                                      [[:f13 [:launcher "/Applications/Discord"]]]}
  {:des "F14" :rules                                      [[:f14 [:launcher "/Applications/Discord"]]]}
  {:des "F16" :rules                                      [[:f16 :!!f]]}
